{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "frontend/package.json", "use": "@vercel/static-build" }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },

    {
      "handle": "filesystem"
    },

    {
      "src": "/(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}
